<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/parent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000"
    tools:context="com.dsource.idc.jellowintl.make_my_board_module.activity.BoardListActivity"
    android:fitsSystemWindows="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/light_base">
                <include
                    android:id="@+id/custom_app_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-10dp"
                    layout="@layout/app_bar"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/custom_app_bar"
                    android:layout_marginBottom="@dimen/list_recycler_margin"
                    android:layout_marginHorizontal="@dimen/list_recycler_margin"
                    android:fadeScrollbars="false"
                    android:scrollbarSize="4dp"
                    android:scrollbars="vertical"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior"
                    android:fitsSystemWindows="true"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:id="@+id/place_holder_text"
                    android:textSize="24sp"
                    android:text="@string/board_place_holder_text"
                    android:textColor="@color/light_grey"
                    android:fitsSystemWindows="true"/>
        </RelativeLayout>
</LinearLayout>

